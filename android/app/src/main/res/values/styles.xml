<?xml version="1.0" encoding="utf-8"?>
<!--suppress ALL -->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- Match the background of your lib/pages/splash_screen.dart -->
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>

    <style name="ScheduleWidgetDialogTheme" parent="@android:style/Theme.Material.Light.Dialog.Alert">
        <item name="android:windowCloseOnTouchOutside">true</item>
        <item name="android:colorAccent">#1976D2</item>
    </style>

    <style name="ScheduleWidgetRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/schedule_widget_row_background</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="ScheduleWidgetDate">
        <item name="android:layout_width">58dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#93C5FD</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ScheduleWidgetDetails">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#F8FAFC</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="ScheduleWidgetWeekday">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#606060</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="ScheduleWidgetCalendarRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="ScheduleWidgetLegendDot">
        <item name="android:layout_width">10dp</item>
        <item name="android:layout_height">10dp</item>
        <item name="android:layout_marginStart">5dp</item>
        <item name="android:layout_marginEnd">5dp</item>
    </style>

    <style name="ScheduleWidgetLegendText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:textColor">#9CA3AF</item>
        <item name="android:textSize">10sp</item>
    </style>
</resources>
